# Copy to .env.local for local development.
# Base URL of the Laravel backend API. Consumed by src/lib/api.ts (which also
# falls back to http://localhost:8000) AND by pages that read
# process.env.NEXT_PUBLIC_API_URL directly (those have NO fallback, so without
# this set their fetches hit "undefined/api/..." and fail to load).
# In production this is configured in Vercel, not committed here.
NEXT_PUBLIC_API_URL=http://localhost:8000
